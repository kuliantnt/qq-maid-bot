# Compose project 名称用于隔离容器、网络和多实例资源。
COMPOSE_PROJECT_NAME=qq-maid-bot

# 正式部署优先使用 digest；本地构建验证可以临时使用 qq-maid-bot:dev。
QQ_MAID_IMAGE=ghcr.io/kuliantnt/qq-maid-bot@sha256:请替换为64位镜像digest

# 容器内固定使用 10001:10001；宿主机目录需允许该 UID/GID 读写。
QQ_MAID_UID=10001
QQ_MAID_GID=10001
QQ_MAID_ENV_FILE=./runtime/config/.env
QQ_MAID_CONFIG_DIR=./runtime/config
QQ_MAID_DATA_DIR=./runtime/data
QQ_MAID_MEDIA_DIR=./runtime/media

# 使用对应 compose.*.yaml 覆盖时按实例设置宿主机端口；默认仅绑定 127.0.0.1。
QQ_MAID_HTTP_PORT=8787
QQ_MAID_WECHAT_PORT=8788
QQ_MAID_ONEBOT_PORT=8789
